{
  "name": "co-caisse",
  "version": "1.0.0",
  "description": "Application de gestion de caisse générique et configurable",
  "main": "main.js",
  "homepage": "./",
  "scripts": {
    "start": "electron .",
    "dev": "concurrently \"npm run renderer\" \"wait-on http://localhost:3000 && electron .\"",
    "renderer": "npm run renderer --prefix client",
    "build-renderer": "npm run build-renderer --prefix client",
    "build": "npm run build-renderer && electron-builder",
    "electron-build": "electron-builder",
    "dist:win": "npm run build-renderer && electron-builder --win",
    "dist:portable": "npm run build-renderer && electron-builder --win portable"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "body-parser": "^1.20.2",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "electron-is-dev": "^3.0.1",
    "express": "^4.18.2",
    "idb": "^8.0.0",
    "jsonwebtoken": "^9.0.3",
    "mysql2": "^3.17.4",
    "sqlite3": "^5.1.6",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.23.0",
    "@babel/preset-env": "^7.23.0",
    "autoprefixer": "^10.4.16",
    "babel-loader": "^9.1.3",
    "concurrently": "^8.2.1",
    "css-loader": "^7.1.3",
    "electron": "^27.0.0",
    "electron-builder": "^24.9.1",
    "eslint": "^8.50.0",
    "html-webpack-plugin": "^5.5.3",
    "jest": "^29.7.0",
    "postcss": "^8.4.31",
    "postcss-loader": "^8.2.0",
    "style-loader": "^4.0.0",
    "tailwindcss": "^3.3.0",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4",
    "wait-on": "^7.2.0",
    "webpack-dev-server": "^4.15.1"
  },
  "build": {
    "appId": "com.cocaisse.app",
    "productName": "Co-Caisse",
    "copyright": "Copyright © 2026 Co-Caisse",
    "files": [
      "client/dist/**/*",
      "main.js",
      "preload.js",
      "package.json"
    ],
    "directories": {
      "buildResources": "assets",
      "output": "release"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico",
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Co-Caisse"
    },
    "portable": {
      "artifactName": "${productName}-Portable-${version}.${ext}"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "assets/icon.icns",
      "category": "public.app-category.business"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "assets/icon.png",
      "category": "Office"
    }
  }
}
